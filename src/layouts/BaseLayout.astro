---
import '../styles/global.css';
import {
  faBook,
  faBrain,
  faBars,
  faCompassDrafting,
  faDesktop,
  faGlobe,
  faMagnifyingGlass,
  faMoon,
  faRobot,
  faRuler,
  faSun,
  faWrench,
} from '@fortawesome/free-solid-svg-icons';
import { withBase } from '../lib/site';

type Props = {
  title: string;
  description?: string;
  sourceUrl?: string;
  breadcrumbs?: { label: string; href?: string }[];
};

const {
  title,
  description = 'Durable software-development preferences.',
  sourceUrl,
  breadcrumbs = [],
} = Astro.props;
const isHomePage = title === 'Practice' || title === 'Software Practices';
const breadcrumbsIncludeCurrent = breadcrumbs.at(-1)?.href === undefined && breadcrumbs.length > 0;
const currentBreadcrumb = breadcrumbsIncludeCurrent ? undefined : title;
const showBreadcrumbs = !isHomePage || breadcrumbs.length > 0;
const themeIcons = {
  system: faDesktop,
  light: faSun,
  dark: faMoon,
};
const menuIcon = faBars;
const searchIcon = faMagnifyingGlass;
const primaryLinks = [
  { label: 'Guides', href: '/guides/' },
  { label: 'Rules', href: '/rules/' },
  { label: 'Patterns', href: '/patterns/' },
  { label: 'Principles', href: '/why/' },
  { label: 'Mechanisms', href: '/mechanisms/' },
  { label: 'Agents', href: '/agents/' },
  { label: 'References', href: '/references/' },
];
const searchKindIcons = {
  agent: iconData(faRobot),
  guide: iconData(faBook),
  mechanism: iconData(faWrench),
  page: iconData(faGlobe),
  pattern: iconData(faCompassDrafting),
  principle: iconData(faBrain),
  reference: iconData(faGlobe),
  rule: iconData(faRuler),
};

function iconPath(icon: (typeof themeIcons)[keyof typeof themeIcons]): string {
  const [, , , , path] = icon.icon;
  return Array.isArray(path) ? path.join(' ') : path;
}

function iconData(icon: typeof faRuler): { path: string; viewBox: string } {
  return {
    path: iconPath(icon),
    viewBox: `0 0 ${icon.icon[0]} ${icon.icon[1]}`,
  };
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=JetBrains+Mono:wght@500;600&amp;display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      const storedTheme = localStorage.getItem('theme-preference');
      const systemTheme = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      const themePreference = storedTheme === 'light' || storedTheme === 'dark' ? storedTheme : 'system';
      document.documentElement.dataset.theme = themePreference === 'system' ? systemTheme : themePreference;
      document.documentElement.dataset.themePreference = themePreference;
    </script>
    <title>{title === 'Practice' ? title : `${title} | Practice`}</title>
  </head>
  <body
    class="min-h-screen bg-background text-on-background font-sans text-base antialiased"
    data-search-index={withBase('/search.json')}
    data-search-kind-icons={JSON.stringify(searchKindIcons)}
  >
    <header class="site-header sticky top-0 z-50">
      <div class="site-header__inner">
        <a class="flex min-w-max items-center gap-3 text-on-background no-underline" href={withBase('/')}>
          <img
            class="size-8 rounded-lg"
            src="https://github.com/joshka.png?size=64"
            alt="Joshka"
            width="32"
            height="32"
            decoding="async"
          />
          <span class="min-w-0">
            <span class="block text-base font-bold leading-tight">Software Practices</span>
            <span class="block text-xs leading-tight text-on-surface-variant">
              Code, docs, tests, review, and coding agents
            </span>
          </span>
        </a>
        <div class="site-header__actions">
          <nav class="primary-nav" aria-label="Primary">
            {primaryLinks.map((link) => <a class="nav-link" href={withBase(link.href)}>{link.label}</a>)}
          </nav>
          <div class="mobile-nav">
            <button
              class="mobile-nav__trigger"
              type="button"
              aria-label="Open section navigation"
              aria-expanded="false"
              aria-controls="mobile-primary-nav"
              data-mobile-nav-trigger
            >
              <svg aria-hidden="true" viewBox={`0 0 ${menuIcon.icon[0]} ${menuIcon.icon[1]}`}>
                <path d={iconPath(menuIcon)} />
              </svg>
            </button>
            <nav class="mobile-nav__menu" id="mobile-primary-nav" aria-label="Primary" hidden>
              {primaryLinks.map((link) => <a class="mobile-nav__link" href={withBase(link.href)}>{link.label}</a>)}
            </nav>
          </div>
          <button
            class="site-search-trigger"
            type="button"
            aria-label="Search site"
            aria-keyshortcuts="Meta+K Control+K"
            data-search-trigger
          >
            <svg aria-hidden="true" viewBox={`0 0 ${searchIcon.icon[0]} ${searchIcon.icon[1]}`}>
              <path d={iconPath(searchIcon)} />
            </svg>
          </button>
          <div class="theme-switcher">
            <button
              class="theme-switcher__trigger"
              type="button"
              aria-label="Choose theme mode"
              aria-expanded="false"
              aria-haspopup="menu"
            >
              {Object.entries(themeIcons).map(([name, icon]) => (
                <svg
                  class="theme-switcher__current"
                  data-theme-current={name}
                  aria-hidden="true"
                  viewBox={`0 0 ${icon.icon[0]} ${icon.icon[1]}`}
                >
                  <path d={iconPath(icon)} />
                </svg>
              ))}
            </button>
            <div class="theme-switcher__menu" role="menu" hidden>
              {Object.entries(themeIcons).map(([name, icon]) => (
                <button
                  class="theme-switcher__option"
                  type="button"
                  data-theme-option={name}
                  role="menuitemradio"
                  aria-checked="false"
                >
                  <svg aria-hidden="true" viewBox={`0 0 ${icon.icon[0]} ${icon.icon[1]}`}>
                    <path d={iconPath(icon)} />
                  </svg>
                  <span>{name}</span>
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
    </header>
    <main class="main-shell mx-auto w-full max-w-container px-page py-8 md:px-page-lg md:py-12">
      {showBreadcrumbs && (
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <a href={withBase('/')}>Home</a>
          {breadcrumbs.map((crumb) => (
            <>
              <span aria-hidden="true">/</span>
              {crumb.href ? (
                <a href={withBase(crumb.href)}>{crumb.label}</a>
              ) : (
                <span aria-current="page">{crumb.label}</span>
              )}
            </>
          ))}
          {currentBreadcrumb && (
            <>
              <span aria-hidden="true">/</span>
              <span aria-current="page">{currentBreadcrumb}</span>
            </>
          )}
        </nav>
      )}
      <slot />
    </main>
    <div class="site-search" data-search-dialog hidden>
      <button class="site-search__backdrop" type="button" aria-label="Close search" data-search-close></button>
      <section class="site-search__panel" role="dialog" aria-modal="true" aria-label="Search site">
        <div class="site-search__field">
          <svg aria-hidden="true" viewBox={`0 0 ${searchIcon.icon[0]} ${searchIcon.icon[1]}`}>
            <path d={iconPath(searchIcon)} />
          </svg>
          <input
            type="search"
            placeholder="Search rules, guides, patterns..."
            autocomplete="off"
            spellcheck="false"
            data-search-input
          />
        </div>
        <div class="site-search__results" data-search-results>
          <p class="site-search__empty">Start typing to search the site.</p>
        </div>
      </section>
    </div>
    <footer class="site-footer mx-auto flex w-full max-w-container flex-col gap-4 px-page py-8 text-sm text-on-surface-variant md:flex-row md:items-center md:justify-between md:px-page-lg">
      <div class="site-footer__text">
        <p>Durable software practices for code, documentation, tests, review, and coding agents.</p>
        <p>
          Copyright © 2026 Josh McKinney · <a href="https://joshka.net/practice/">joshka.net/practice</a>
        </p>
      </div>
      {sourceUrl && <a class="footer-source" href={sourceUrl}>Edit source</a>}
    </footer>
    <script>
      const themeQuery = window.matchMedia('(prefers-color-scheme: light)');
      const themeSwitcher = document.querySelector('.theme-switcher');
      const themeTrigger = document.querySelector('.theme-switcher__trigger');
      const themeMenu = document.querySelector('.theme-switcher__menu');
      const themeButtons = document.querySelectorAll('[data-theme-option]');
      const mobileNav = document.querySelector('.mobile-nav');
      const mobileNavTrigger = document.querySelector('[data-mobile-nav-trigger]');
      const mobileNavMenu = document.querySelector('.mobile-nav__menu');
      const searchDialog = document.querySelector('[data-search-dialog]');
      const searchInput = document.querySelector('[data-search-input]');
      const searchResults = document.querySelector('[data-search-results]');
      const searchTriggers = document.querySelectorAll('[data-search-trigger]');
      const searchCloseButtons = document.querySelectorAll('[data-search-close]');

      type ThemePreference = 'system' | 'light' | 'dark';
      type SearchEntry = {
        title: string;
        id?: string;
        kind: string;
        kindLabel: string;
        description: string;
        url: string;
        headings: string[];
        text: string;
      };
      type SearchResult = SearchEntry & {
        score: number;
        snippet: string;
      };

      function themePreference(): ThemePreference {
        const stored = localStorage.getItem('theme-preference');
        return stored === 'light' || stored === 'dark' ? stored : 'system';
      }

      function resolvedTheme(preference: ThemePreference): 'light' | 'dark' {
        return preference === 'system' ? (themeQuery.matches ? 'light' : 'dark') : preference;
      }

      function applyTheme(preference: ThemePreference) {
        document.documentElement.dataset.themePreference = preference;
        document.documentElement.dataset.theme = resolvedTheme(preference);
        for (const button of themeButtons) {
          const active = button instanceof HTMLElement && button.dataset.themeOption === preference;
          button.setAttribute('aria-checked', String(active));
        }
      }

      applyTheme(themePreference());

      themeTrigger?.addEventListener('click', () => {
        if (!(themeTrigger instanceof HTMLElement) || !(themeMenu instanceof HTMLElement)) return;
        const expanded = themeTrigger.getAttribute('aria-expanded') === 'true';
        themeTrigger.setAttribute('aria-expanded', String(!expanded));
        themeMenu.hidden = expanded;
      });

      for (const button of themeButtons) {
        button.addEventListener('click', () => {
          if (!(button instanceof HTMLElement)) return;
          const preference = button.dataset.themeOption;
          if (preference !== 'system' && preference !== 'light' && preference !== 'dark') return;

          if (preference === 'system') {
            localStorage.removeItem('theme-preference');
          } else {
            localStorage.setItem('theme-preference', preference);
          }
          applyTheme(preference);
          if (themeTrigger instanceof HTMLElement) themeTrigger.setAttribute('aria-expanded', 'false');
          if (themeMenu instanceof HTMLElement) themeMenu.hidden = true;
        });
      }

      document.addEventListener('click', (event) => {
        if (!(themeSwitcher instanceof HTMLElement) || !(themeMenu instanceof HTMLElement)) return;
        if (event.target instanceof Node && themeSwitcher.contains(event.target)) return;
        themeMenu.hidden = true;
        if (themeTrigger instanceof HTMLElement) themeTrigger.setAttribute('aria-expanded', 'false');
      });

      themeQuery.addEventListener('change', () => {
        if (themePreference() === 'system') applyTheme('system');
      });

      function closeMobileNav() {
        if (!(mobileNavTrigger instanceof HTMLElement) || !(mobileNavMenu instanceof HTMLElement)) return;
        mobileNavTrigger.setAttribute('aria-expanded', 'false');
        mobileNavMenu.hidden = true;
      }

      mobileNavTrigger?.addEventListener('click', () => {
        if (!(mobileNavTrigger instanceof HTMLElement) || !(mobileNavMenu instanceof HTMLElement)) return;
        const expanded = mobileNavTrigger.getAttribute('aria-expanded') === 'true';
        mobileNavTrigger.setAttribute('aria-expanded', String(!expanded));
        mobileNavMenu.hidden = expanded;
      });

      document.addEventListener('click', (event) => {
        if (!(mobileNav instanceof HTMLElement)) return;
        if (event.target instanceof Node && mobileNav.contains(event.target)) return;
        closeMobileNav();
      });

      let searchIndex: SearchEntry[] | undefined;
      let selectedSearchIndex = 0;
      const rawSearchKindIcons = document.body.dataset.searchKindIcons || '{}';
      const searchKindIcons = JSON.parse(rawSearchKindIcons) as Record<string, { path: string; viewBox: string }>;

      function normalizeSearchText(value: string): string {
        return value.toLowerCase().replace(/\s+/g, ' ').trim();
      }

      async function loadSearchIndex(): Promise<SearchEntry[]> {
        if (searchIndex) return searchIndex;
        const url = document.body.dataset.searchIndex;
        if (!url) return [];
        const response = await fetch(url);
        searchIndex = await response.json() as SearchEntry[];
        return searchIndex;
      }

      function searchSnippet(text: string, tokens: string[]): string {
        const normalized = normalizeSearchText(text);
        const matchIndex = tokens
          .map((token) => normalized.indexOf(token))
          .filter((index) => index >= 0)
          .sort((a, b) => a - b)[0] ?? 0;
        const start = Math.max(0, matchIndex - 72);
        const end = Math.min(text.length, matchIndex + 168);
        const prefix = start > 0 ? '...' : '';
        const suffix = end < text.length ? '...' : '';
        return `${prefix}${text.slice(start, end).trim()}${suffix}`;
      }

      function scoreSearchEntry(entry: SearchEntry, tokens: string[], query: string): SearchResult | undefined {
        const title = normalizeSearchText(entry.title);
        const id = normalizeSearchText(entry.id || '');
        const description = normalizeSearchText(entry.description);
        const headings = normalizeSearchText(entry.headings.join(' '));
        const text = normalizeSearchText(entry.text);

        if (!tokens.every((token) => text.includes(token))) return undefined;

        let score = 0;
        if (title === query) score += 80;
        if (id === query) score += 95;
        if (title.startsWith(query)) score += 45;
        if (id.startsWith(query)) score += 65;
        if (title.includes(query)) score += 30;
        if (id.includes(query)) score += 45;
        if (description.includes(query)) score += 12;
        if (headings.includes(query)) score += 18;
        for (const token of tokens) {
          if (id.includes(token)) score += 18;
          if (title.includes(token)) score += 12;
          if (headings.includes(token)) score += 8;
          if (description.includes(token)) score += 4;
          if (text.includes(token)) score += 1;
        }

        return {
          ...entry,
          score,
          snippet: searchSnippet(entry.text, tokens),
        };
      }

      function renderSearchResults(results: SearchResult[]) {
        if (!(searchResults instanceof HTMLElement)) return;
        if (results.length === 0) {
          searchResults.innerHTML = '<p class="site-search__empty">No matching pages.</p>';
          return;
        }

        searchResults.innerHTML = results
          .map((result, index) => {
            const icon = searchKindIcons[result.kind] || searchKindIcons.page;
            return `
            <a class="site-search__result" href="${result.url}" data-search-result data-index="${index}" aria-selected="${index === selectedSearchIndex}">
              <span class="site-search__result-meta">
                <span class="site-search__kind">
                  <svg aria-hidden="true" viewBox="${escapeSearchHtml(icon.viewBox)}">
                    <path d="${escapeSearchHtml(icon.path)}"></path>
                  </svg>
                  <em>${escapeSearchHtml(result.kindLabel)}</em>
                </span>
                ${result.id ? `<small>${escapeSearchHtml(result.id)}</small>` : ''}
              </span>
              <strong>${escapeSearchHtml(result.title)}</strong>
              <span class="site-search__result-description">${escapeSearchHtml(result.description || result.snippet)}</span>
            </a>
          `;
          })
          .join('');
      }

      async function updateSearchResults() {
        if (!(searchInput instanceof HTMLInputElement) || !(searchResults instanceof HTMLElement)) return;
        const query = normalizeSearchText(searchInput.value);
        if (!query) {
          selectedSearchIndex = 0;
          searchResults.innerHTML = '<p class="site-search__empty">Start typing to search the site.</p>';
          return;
        }

        const tokens = query.split(' ').filter(Boolean);
        const results = (await loadSearchIndex())
          .map((entry) => scoreSearchEntry(entry, tokens, query))
          .filter((result): result is SearchResult => Boolean(result))
          .sort((a, b) => b.score - a.score || a.title.localeCompare(b.title))
          .slice(0, 8);
        selectedSearchIndex = 0;
        renderSearchResults(results);
      }

      function openSearch() {
        if (!(searchDialog instanceof HTMLElement) || !(searchInput instanceof HTMLInputElement)) return;
        searchDialog.hidden = false;
        document.body.classList.add('site-search-open');
        window.setTimeout(() => searchInput.focus(), 0);
        void loadSearchIndex();
      }

      function closeSearch() {
        if (!(searchDialog instanceof HTMLElement)) return;
        searchDialog.hidden = true;
        document.body.classList.remove('site-search-open');
      }

      function selectedSearchResult(): HTMLAnchorElement | undefined {
        if (!(searchResults instanceof HTMLElement)) return undefined;
        const results = Array.from(searchResults.querySelectorAll<HTMLAnchorElement>('[data-search-result]'));
        return results[selectedSearchIndex];
      }

      function moveSearchSelection(direction: number) {
        if (!(searchResults instanceof HTMLElement)) return;
        const results = Array.from(searchResults.querySelectorAll<HTMLElement>('[data-search-result]'));
        if (results.length === 0) return;
        selectedSearchIndex = (selectedSearchIndex + direction + results.length) % results.length;
        for (const [index, result] of results.entries()) {
          result.setAttribute('aria-selected', String(index === selectedSearchIndex));
        }
      }

      function escapeSearchHtml(value: string): string {
        return value
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;');
      }

      for (const trigger of searchTriggers) {
        trigger.addEventListener('click', openSearch);
      }

      for (const button of searchCloseButtons) {
        button.addEventListener('click', closeSearch);
      }

      searchInput?.addEventListener('input', () => {
        void updateSearchResults();
      });

      document.addEventListener('keydown', (event) => {
        const target = event.target;
        const isEditable =
          target instanceof HTMLInputElement ||
          target instanceof HTMLTextAreaElement ||
          target instanceof HTMLSelectElement ||
          (target instanceof HTMLElement && target.isContentEditable);

        if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') {
          event.preventDefault();
          openSearch();
          return;
        }

        if (event.key === 'Escape') {
          closeMobileNav();
        }

        if (!(searchDialog instanceof HTMLElement) || searchDialog.hidden) return;
        if (event.key === 'Escape') {
          event.preventDefault();
          closeSearch();
        } else if (event.key === 'ArrowDown') {
          event.preventDefault();
          moveSearchSelection(1);
        } else if (event.key === 'ArrowUp') {
          event.preventDefault();
          moveSearchSelection(-1);
        } else if (event.key === 'Enter' && isEditable) {
          const result = selectedSearchResult();
          if (result) window.location.href = result.href;
        }
      });

      for (const pre of document.querySelectorAll('pre')) {
        if (!(pre.firstElementChild instanceof HTMLElement) || pre.firstElementChild.tagName !== 'CODE') {
          continue;
        }

        let block = pre.parentElement;
        if (!block?.classList.contains('code-block')) {
          block = document.createElement('div');
          block.className = 'code-block';
          pre.replaceWith(block);
          block.append(pre);
        }

        if (block.querySelector('.code-block__copy')) continue;

        const button = document.createElement('button');
        button.className = 'code-block__copy';
        button.type = 'button';
        button.textContent = 'Copy';
        block.prepend(button);
      }

      document.addEventListener('click', async (event) => {
        const markdownButton = event.target instanceof Element ? event.target.closest('[data-copy-markdown]') : null;
        if (markdownButton instanceof HTMLButtonElement) {
          const markdown = markdownButton.dataset.copyMarkdown;
          if (!markdown) return;

          await navigator.clipboard.writeText(markdown);
          const originalText = markdownButton.textContent;
          markdownButton.textContent = 'Copied';
          window.setTimeout(() => {
            markdownButton.textContent = originalText;
          }, 1200);
          return;
        }

        const button = event.target instanceof Element ? event.target.closest('.code-block__copy') : null;
        if (!(button instanceof HTMLButtonElement)) return;

        const code = button.closest('.code-block')?.querySelector('pre code')?.textContent;
        if (!code) return;

        await navigator.clipboard.writeText(code);
        button.textContent = 'Copied';
        window.setTimeout(() => {
          button.textContent = 'Copy';
        }, 1200);
      });
    </script>
  </body>
</html>
