---
import BaseLayout from '../../layouts/BaseLayout.astro';
import KindIcon from '../../components/KindIcon.astro';
import {
  type MarkdownPage,
  getSection,
  practiceTasks,
  sectionIndex,
  sectionPages,
  sections,
  withBase,
} from '../../lib/site';

type SectionConfig = {
  eyebrow: string;
  intro: string;
  listingTitle: string;
  density: 'compact' | 'standard' | 'dense';
};

type GroupConfig = {
  key: string;
  title: string;
  description: string;
  hideTags?: string[];
};

type GroupedEntry = {
  item: MarkdownPage;
  tags: string[];
};

type CardKind = 'agent' | 'guide' | 'pattern' | 'principle' | 'mechanism' | 'reference';

export function getStaticPaths() {
  return sections.map((section) => ({ params: { section: section.key } }));
}

const section = getSection(Astro.params.section ?? '');
if (!section) throw new Error(`Unknown section: ${Astro.params.section}`);
const sectionKey = section.key;
const sectionTitle = section.title;
const sectionDescription = section.description;
const page = sectionIndex(section);
const pages = sectionPages(section);
const showGuideTasks = sectionKey === 'guides';
const sectionKind = cardKindForSection(sectionKey);

const sectionConfig: Record<string, SectionConfig> = {
  guides: {
    eyebrow: 'Guide index',
    intro:
      'Guides cover broad decisions that span rules, patterns, principles, and mechanisms.',
    listingTitle: 'Available guides',
    density: 'standard',
  },
  patterns: {
    eyebrow: 'Pattern library',
    intro:
      'Patterns name repeatable development situations and the preferred moves that fit them. They work as review terms, guide links, and compact agent instructions.',
    listingTitle: 'Pattern areas',
    density: 'dense',
  },
  why: {
    eyebrow: 'Principles',
    intro:
      'Principles capture the rationale, tradeoffs, and limits behind related rules and patterns.',
    listingTitle: 'Principle areas',
    density: 'dense',
  },
  mechanisms: {
    eyebrow: 'Checks and workflows',
    intro:
      'Mechanisms are checks, commands, generators, and workflows that make preferences easier to follow and harder to forget.',
    listingTitle: 'Mechanism areas',
    density: 'compact',
  },
  agents: {
    eyebrow: 'Agent snippets',
    intro:
      'Agent snippets are copyable instruction packs for downstream repositories, grouped by the work they affect.',
    listingTitle: 'Snippet areas',
    density: 'compact',
  },
  references: {
    eyebrow: 'Source material',
    intro:
      'References collect durable sources and planning records that support, contrast, or frame the guidance.',
    listingTitle: 'Reference areas',
    density: 'compact',
  },
};

const config = sectionConfig[sectionKey] ?? {
  eyebrow: section.title,
  intro: section.description,
  listingTitle: section.title,
  density: 'standard',
};

const guideGroups: Record<string, GroupConfig> = {
  core: {
    key: 'core',
    title: 'Change, code, and Rust',
    description: 'Change scope, code structure, and Rust maintainability.',
    hideTags: ['change', 'code', 'rust'],
  },
  boundaries: {
    key: 'boundaries',
    title: 'Boundaries and feedback',
    description: 'Input, state, failure, diagnostics, and review evidence.',
    hideTags: ['api', 'failure'],
  },
  collaboration: {
    key: 'collaboration',
    title: 'Documentation, agents, and source control',
    description: 'Documentation, agent handoff, jj workflow, and review-facing context.',
    hideTags: ['docs', 'agents', 'vcs'],
  },
};

const patternGroups: Record<string, GroupConfig> = {
  agents: {
    key: 'agents',
    title: 'Agent work',
    description: 'Agent steering, constraints, review, and feedback loops.',
    hideTags: ['agents'],
  },
  docs: {
    key: 'docs',
    title: 'Documentation and shared context',
    description: 'Docs as contracts, source prose, examples, summaries, and review context.',
    hideTags: ['documentation', 'docs', 'markdown'],
  },
  code: {
    key: 'code',
    title: 'Code shape and APIs',
    description: 'Reader-local code, Rust APIs, naming, state shape, and refactoring.',
    hideTags: ['rust', 'readability', 'api-design'],
  },
  correctness: {
    key: 'correctness',
    title: 'Boundaries, failure, and verification',
    description: 'Parsing, validation, errors, observability, tests, and runtime proof.',
    hideTags: ['testing', 'errors', 'observability', 'validation'],
  },
  workflow: {
    key: 'workflow',
    title: 'Change and review workflow',
    description: 'Review size, source control, sequencing, and collaboration.',
    hideTags: ['workflow', 'review', 'version-control'],
  },
  tooling: {
    key: 'tooling',
    title: 'Tooling and automation',
    description: 'Repeated feedback made mechanical without hiding judgment.',
    hideTags: ['tooling', 'automation'],
  },
};

const principleGroups: Record<string, GroupConfig> = {
  agents: {
    key: 'agents',
    title: 'Agents and shared context',
    description: 'Agent instructions, public rationale, and repeated feedback.',
    hideTags: ['agents'],
  },
  change: {
    key: 'change',
    title: 'Change, review, and locality',
    description: 'Change shape, reader locality, and review cost.',
    hideTags: ['change-shape', 'review'],
  },
  boundaries: {
    key: 'boundaries',
    title: 'Boundaries, APIs, and state',
    description: 'Explicit boundaries, public API cost, and mutable state.',
    hideTags: ['boundaries', 'api', 'state'],
  },
  verification: {
    key: 'verification',
    title: 'Testing and performance',
    description: 'Useful test failures and evidence-backed optimization.',
    hideTags: ['testing', 'performance'],
  },
  vcs: {
    key: 'vcs',
    title: 'Version-control topology',
    description: 'JJ, remotes, bookmarks, and publication shape.',
    hideTags: ['jj', 'vcs'],
  },
};

const mechanismGroups: Record<string, GroupConfig> = {
  guidance: {
    key: 'guidance',
    title: 'Guidance system',
    description: 'Generated snippets, templates, indexes, and rule synchronization.',
    hideTags: ['guidance', 'rules'],
  },
  vcs: {
    key: 'vcs',
    title: 'JJ workflow',
    description: 'Source-control state, noninteractive jj commands, and agent-safe workflow.',
    hideTags: ['jj', 'git', 'vcs'],
  },
  rust: {
    key: 'rust',
    title: 'Rust checks',
    description: 'Rust API, release, docs, lint, formatting, and tooling checks.',
    hideTags: ['rust', 'cargo'],
  },
  testing: {
    key: 'testing',
    title: 'Testing and benchmarking',
    description: 'Validation cost, risk, and expected feedback value.',
    hideTags: ['tests', 'testing', 'benchmarks'],
  },
};

const agentGroups: Record<string, GroupConfig> = {
  baseline: {
    key: 'baseline',
    title: 'Baseline packs',
    description: 'Core instructions and rule packs for downstream projects.',
    hideTags: ['baseline'],
  },
  domain: {
    key: 'domain',
    title: 'Project areas',
    description: 'Snippets for Rust, docs, and source control.',
    hideTags: ['rust', 'docs', 'vcs'],
  },
  workflow: {
    key: 'workflow',
    title: 'Workflow guidance',
    description: 'Task setup, review, and handoff guidance for coding agents.',
    hideTags: ['workflow'],
  },
};

const referenceGroups: Record<string, GroupConfig> = {
  sources: {
    key: 'sources',
    title: 'External sources',
    description: 'Durable sources that support, adapt, or contrast guidance in this repo.',
    hideTags: ['sources'],
  },
  planning: {
    key: 'planning',
    title: 'Planning records',
    description: 'Planning records for current structure and future guidance work.',
    hideTags: ['plan'],
  },
};

const guideTags: Record<string, string[]> = {
  'Boundary Correctness': ['API', 'STATE', 'INPUT'],
  'Code Shape': ['CODE', 'READING'],
  'Coding Agents': ['AGENTS', 'WORKFLOW'],
  'Documentation Workflow': ['DOCS', 'REVIEW'],
  'JJ Workflow': ['VCS', 'JJ'],
  'Markdown and Documentation': ['MARKDOWN', 'DOCS'],
  'Observability and Failure': ['FAILURE', 'DIAGNOSTICS'],
  'Rust Maintainability': ['RUST', 'API'],
  'Software Change Preferences': ['CHANGE', 'REVIEW'],
};

const snippetTags: Record<string, string[]> = {
  'Coding Agents': ['WORKFLOW'],
  Core: ['BASELINE'],
  JJ: ['VCS'],
  'Markdown Docs': ['DOCS'],
  Rules: ['RULE PACK'],
  Rust: ['RUST'],
};

const referenceTags: Record<string, string[]> = {
  'External Source Ledger': ['SOURCES'],
  'Guidance Plan': ['PLAN'],
};

const groupedEntries = groupEntries(pages);
const showGroupNav = groupedEntries.length > 1;

function groupEntries(items: MarkdownPage[]) {
  const groups = groupConfigsForSection();
  const entries = new Map<string, GroupedEntry[]>();
  for (const group of Object.values(groups)) {
    entries.set(group.key, []);
  }

  for (const item of items) {
    const group = groupFor(item);
    const rawTags = tagsFor(item);
    entries.get(group.key)?.push({
      item,
      tags: visibleTags(rawTags, item.title, group),
    });
  }

  return Object.values(groups)
    .map((group) => ({ group, entries: entries.get(group.key) ?? [] }))
    .filter(({ entries }) => entries.length > 0);
}

function groupConfigsForSection(): Record<string, GroupConfig> {
  if (sectionKey === 'guides') return guideGroups;
  if (sectionKey === 'patterns') return patternGroups;
  if (sectionKey === 'why') return principleGroups;
  if (sectionKey === 'mechanisms') return mechanismGroups;
  if (sectionKey === 'agents') return agentGroups;
  if (sectionKey === 'references') return referenceGroups;
  return {
    default: {
      key: 'default',
      title: sectionTitle,
      description: sectionDescription,
    },
  };
}

function groupFor(item: MarkdownPage): GroupConfig {
  if (sectionKey === 'guides') return guideGroupFor(item);
  if (sectionKey === 'patterns') return patternGroupFor(item);
  if (sectionKey === 'why') return principleGroupFor(item);
  if (sectionKey === 'mechanisms') return mechanismGroupFor(item);
  if (sectionKey === 'agents') return agentGroupFor(item);
  if (sectionKey === 'references') return item.title === 'Guidance Plan' ? referenceGroups.planning : referenceGroups.sources;
  return groupConfigsForSection().default;
}

function guideGroupFor(item: MarkdownPage): GroupConfig {
  if (['Software Change Preferences', 'Code Shape', 'Rust Maintainability'].includes(item.title)) {
    return guideGroups.core;
  }
  if (['Boundary Correctness', 'Observability and Failure'].includes(item.title)) {
    return guideGroups.boundaries;
  }
  return guideGroups.collaboration;
}

function patternGroupFor(item: MarkdownPage): GroupConfig {
  const topics = topicsFor(item);
  if (hasAny(topics, ['agents'])) return patternGroups.agents;
  if (hasAny(topics, ['documentation', 'docs', 'markdown', 'rustdoc', 'summaries'])) {
    return patternGroups.docs;
  }
  if (hasAny(topics, ['api-design', 'rust', 'readability', 'refactoring', 'code-shape', 'naming'])) {
    return patternGroups.code;
  }
  if (hasAny(topics, ['testing', 'correctness', 'errors', 'observability', 'validation', 'logging', 'privacy'])) {
    return patternGroups.correctness;
  }
  if (hasAny(topics, ['workflow', 'review', 'version-control', 'jj', 'collaboration'])) {
    return patternGroups.workflow;
  }
  return patternGroups.tooling;
}

function principleGroupFor(item: MarkdownPage): GroupConfig {
  const topics = topicsFor(item);
  if (hasAny(topics, ['agents', 'rules', 'automation', 'communication', 'provenance'])) {
    return principleGroups.agents;
  }
  if (hasAny(topics, ['change-shape', 'review', 'commits', 'refactoring', 'code-shape', 'cognition'])) {
    return principleGroups.change;
  }
  if (hasAny(topics, ['boundaries', 'api', 'state', 'rust', 'semver', 'libraries'])) {
    return principleGroups.boundaries;
  }
  if (hasAny(topics, ['testing', 'performance', 'diagnostics'])) return principleGroups.verification;
  return principleGroups.vcs;
}

function mechanismGroupFor(item: MarkdownPage): GroupConfig {
  const topics = topicsFor(item);
  if (hasAny(topics, ['guidance', 'generated-artifacts', 'markdown'])) return mechanismGroups.guidance;
  if (hasAny(topics, ['jj', 'git', 'workspaces', 'vcs'])) return mechanismGroups.vcs;
  if (hasAny(topics, ['rust', 'cargo', 'rustdoc', 'docs.rs', 'clippy', 'rustfmt'])) return mechanismGroups.rust;
  return mechanismGroups.testing;
}

function agentGroupFor(item: MarkdownPage): GroupConfig {
  if (['snippets/agents/core.md', 'snippets/agents/rules.md'].includes(item.repoPath)) {
    return agentGroups.baseline;
  }
  if (item.repoPath === 'snippets/agents/coding-agents.md') return agentGroups.workflow;
  return agentGroups.domain;
}

function tagsFor(item: MarkdownPage): string[] {
  if (sectionKey === 'guides') return guideTags[item.title] ?? [];
  if (sectionKey === 'agents') return snippetTags[item.title] ?? [];
  if (sectionKey === 'references') return referenceTags[item.title] ?? [];
  return topicTags(item.metadata.topics);
}

function topicTags(topics: string | undefined): string[] {
  return normalizeTopics(topics).map((topic) => topic.toUpperCase()).slice(0, 3);
}

function topicsFor(item: MarkdownPage): string[] {
  return normalizeTopics(item.metadata.topics);
}

function normalizeTopics(topics: string | undefined): string[] {
  if (!topics) return [];
  return topics
    .split(',')
    .map((topic) => topic.trim().toLowerCase())
    .filter(Boolean);
}

function hasAny(topics: string[], values: string[]): boolean {
  return values.some((value) => topics.includes(value));
}

function visibleTags(tags: string[], title: string, group: GroupConfig): string[] {
  const hidden = new Set((group.hideTags ?? []).map((tag) => tag.toLowerCase()));
  const normalizedTitle = normalizeForCompare(title);
  const visible = tags.filter((tag) => {
    const normalized = normalizeForCompare(tag);
    return normalized && !hidden.has(tag.toLowerCase()) && !normalizedTitle.includes(normalized);
  });
  return [...new Set(visible)].slice(0, 3);
}

function normalizeForCompare(value: string): string {
  return value.toLowerCase().replace(/[^a-z0-9]+/g, '');
}

function cardKindForSection(key: string): CardKind | undefined {
  if (key === 'agents') return 'agent';
  if (key === 'guides') return 'guide';
  if (key === 'references') return 'reference';
  if (key === 'patterns') return 'pattern';
  if (key === 'why') return 'principle';
  if (key === 'mechanisms') return 'mechanism';
  return undefined;
}
---

<BaseLayout
  title={page.title}
  description={page.description}
  sourceUrl={page.sourceUrl}
>
  <section class="section-hero" aria-labelledby="section-title">
    <p class="eyebrow">{config.eyebrow}</p>
    <div class="hero-title">
      {sectionKind && (
        <span class="hero-title__icon" aria-hidden="true">
          <KindIcon kind={sectionKind} />
        </span>
      )}
      <h1 id="section-title">{section.title}</h1>
    </div>
    <p>{config.intro}</p>
  </section>

  {showGuideTasks && (
    <section class="section-task-panel" aria-labelledby="guide-task-title">
      <div class="section-task-panel__intro">
        <p class="eyebrow">Guide entry points</p>
        <h2 id="guide-task-title">Work areas</h2>
        <p>
          Change shape, Rust review, documentation, coding-agent work, and jj workflow each have a
          guide entry.
        </p>
      </div>
      <div class="task-grid task-grid--compact">
        {practiceTasks.map((task) => (
          <a class="task-card" href={withBase(task.route)}>
            <strong>{task.title}</strong>
            <span>{task.description}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="listing">
    <div class="listing__header">
      <h2>{config.listingTitle}</h2>
      {showGroupNav && (
        <nav class="group-nav" aria-label={`${section.title} groups`}>
          {groupedEntries.map(({ group, entries }) => (
            <a href={`#group-${group.key}`}>
              <span>{group.title}</span>
              <small>{entries.length}</small>
            </a>
          ))}
        </nav>
      )}
    </div>
    <div class={`grouped-index grouped-index--${config.density}`}>
      {groupedEntries.map(({ group, entries }) => (
        <section class="index-group" aria-labelledby={`group-${group.key}`}>
          <div class="index-group__header">
            <h3 id={`group-${group.key}`}>{group.title}</h3>
            <p>{group.description}</p>
          </div>
          <div class="index-list index-list--cards">
            {entries.map(({ item, tags }) => (
              <a class={`index-entry ${sectionKind ? 'index-entry--with-icon' : ''}`} href={withBase(item.route)}>
                <span class="index-entry__body">
                  {tags.length > 0 && (
                    <span class="index-entry__tags">
                      {tags.map((tag) => (
                        <span class="index-entry__tag">{tag}</span>
                      ))}
                    </span>
                  )}
                  <span class="index-entry__title">
                    {sectionKind && (
                      <span class="index-entry__kind-icon" aria-hidden="true">
                        <KindIcon kind={sectionKind} />
                      </span>
                    )}
                    <strong>{item.title}</strong>
                  </span>
                  {item.description && <span class="index-entry__description">{item.description}</span>}
                </span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
