---
import BaseLayout from '../../layouts/BaseLayout.astro';
import KindIcon from '../../components/KindIcon.astro';
import { withBase } from '../../lib/site';

const colorFamilies = [
  { name: 'Site', className: 'design-color--site', use: 'Brand and site structure' },
  { name: 'Guides', className: 'design-color--guide', use: 'Broad work-area guidance' },
  { name: 'Rules', className: 'design-color--rule', use: 'Compact instructions' },
  { name: 'Patterns', className: 'design-color--pattern', use: 'Repeatable review moves' },
  { name: 'Principles', className: 'design-color--principle', use: 'Rationale and tradeoffs' },
  { name: 'Mechanisms', className: 'design-color--mechanism', use: 'Operational tools' },
  { name: 'Agents', className: 'design-color--agent', use: 'Agent instruction packs' },
  { name: 'Indexes', className: 'design-color--index', use: 'Tags and references' },
];

const kinds = ['guide', 'rule', 'pattern', 'principle', 'mechanism', 'agent', 'tag', 'reference'] as const;
const spacing = [
  ['1', '0.25rem'],
  ['2', '0.5rem'],
  ['3', '0.75rem'],
  ['4', '1rem'],
  ['5', '1.5rem'],
  ['6', '2rem'],
  ['7', '3rem'],
  ['8', '4rem'],
];
---

<BaseLayout
  title="Design System"
  description="The color, typography, spacing, line, icon, control, and layout system used by Software Practices."
  breadcrumbs={[{ label: 'About', href: '/about/' }]}
>
  <section class="section-hero design-system-hero" aria-labelledby="design-system-title">
    <div class="hero-title">
      <h1 id="design-system-title">Design System</h1>
    </div>
    <p>
      A compact reference for the visual rules used across Software Practices. The system borrows
      the clarity of an older reference manual without turning the site into a terminal interface.
    </p>
  </section>

  <div class="design-specimens">
    <section class="design-specimen" aria-labelledby="design-color-title">
      <div class="design-specimen__label">
        <h2 id="design-color-title">Color</h2>
        <p>Hue identifies a content family. Every family uses the same solid, heading, and field roles.</p>
      </div>
      <div class="design-color-grid">
        {colorFamilies.map((family) => (
          <div class={`design-color ${family.className}`}>
            <span class="design-color__field"></span>
            <strong>{family.name}</strong>
            <small>{family.use}</small>
          </div>
        ))}
      </div>
    </section>

    <section class="design-specimen" aria-labelledby="design-type-title">
      <div class="design-specimen__label">
        <h2 id="design-type-title">Typography</h2>
        <p>Serif names things. Sans explains them. Mono carries metadata and compact controls.</p>
      </div>
      <div class="design-type-stack">
        <p class="design-type design-type--display">Reader locality</p>
        <p class="design-type design-type--body">
          Keep the facts a reader needs close to the code or decision they affect.
        </p>
        <p class="design-type design-type--meta">READER-LOCALITY / REVIEWABILITY</p>
      </div>
    </section>

    <section class="design-specimen" aria-labelledby="design-spacing-title">
      <div class="design-specimen__label">
        <h2 id="design-spacing-title">Spacing and lines</h2>
        <p>Spacing follows a short scale. Thin rules separate peers; a thicker rule marks family context.</p>
      </div>
      <div class="design-spacing-scale">
        {spacing.map(([token, value]) => (
          <div class="design-spacing-row">
            <code>{token}</code>
            <span class="design-spacing-bar" style={`--design-space: var(--space-${token})`}></span>
            <small>{value}</small>
          </div>
        ))}
        <div class="design-line design-line--peer"><span>Peer boundary</span></div>
        <div class="design-line design-line--family"><span>Family boundary</span></div>
      </div>
    </section>

    <section class="design-specimen" aria-labelledby="design-icons-title">
      <div class="design-specimen__label">
        <h2 id="design-icons-title">Icons</h2>
        <p>Icons identify artifact type. Color carries the larger family and hierarchy.</p>
      </div>
      <div class="design-icon-grid">
        {kinds.map((kind) => (
          <div class="design-icon">
            <span aria-hidden="true"><KindIcon kind={kind} /></span>
            <small>{kind}</small>
          </div>
        ))}
      </div>
    </section>

    <section class="design-specimen" aria-labelledby="design-controls-title">
      <div class="design-specimen__label">
        <h2 id="design-controls-title">Controls</h2>
        <p>Metadata is quiet, navigation is tinted, and actions use a filled field.</p>
      </div>
      <div class="design-controls">
        <span class="index-entry__tag">Metadata</span>
        <a class="detail-chip" href={withBase('/tags/reader-locality/')}>Navigation</a>
        <a class="inline-action" href={withBase('/guides/')}>Action</a>
      </div>
    </section>

    <section class="design-specimen" aria-labelledby="design-layout-title">
      <div class="design-specimen__label">
        <h2 id="design-layout-title">Layout</h2>
        <p>A stable label column orients the reader; the content column carries the reading flow.</p>
      </div>
      <a class="design-link-panel" href={withBase('/guides/code-shape/')}>
        <span class="design-link-panel__meta">GUIDE / READER LOCALITY</span>
        <span class="design-link-panel__title">
          <strong>Code Shape</strong>
          <span class="card-arrow" aria-hidden="true">→</span>
        </span>
        <span>Local structure, reviewable changes, and manageable live context.</span>
      </a>
    </section>
  </div>
</BaseLayout>
