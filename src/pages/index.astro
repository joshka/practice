---
import BaseLayout from '../layouts/BaseLayout.astro';
import KindIcon from '../components/KindIcon.astro';
import { practiceTasks, withBase } from '../lib/site';

const homeCards = [
  {
    title: 'Guides',
    kind: 'guide' as const,
    route: '/guides/',
    description: 'Connected guidance for broad engineering decisions.',
  },
  {
    title: 'Rules',
    kind: 'rule' as const,
    route: '/rules/',
    description: 'Compact instructions grouped by work area with detail pages for every rule.',
  },
  {
    title: 'Patterns',
    kind: 'pattern' as const,
    route: '/patterns/',
    description: 'Repeatable situations and moves that can be cited in review.',
  },
  {
    title: 'Principles',
    kind: 'principle' as const,
    route: '/why/',
    description: 'Rationale behind related rules and patterns.',
  },
  {
    title: 'Mechanisms',
    kind: 'mechanism' as const,
    route: '/mechanisms/',
    description: 'Checks, commands, generators, and workflows that support the guidance.',
  },
  {
    title: 'Tags',
    kind: 'tag' as const,
    route: '/tags/',
    description: 'Cross-cutting clusters across rules, patterns, principles, and mechanisms.',
  },
  {
    title: 'Agents',
    kind: 'agent' as const,
    route: '/agents/',
    description: 'Copyable instruction packs and rule packs for coding agents.',
  },
];

const useCases = [
  {
    title: 'Review comments',
    route: '/patterns/write-pr-narrative/',
    description:
      'Link a named rule or pattern instead of re-explaining the same preference in every PR.',
  },
  {
    title: 'Project setup',
    route: '/agents/core/',
    description:
      'Copy the downstream `AGENTS.md` template and rule pack, then adapt local checks and constraints.',
  },
  {
    title: 'Agent instructions',
    route: '/agents/',
    description:
      'Agent snippets give coding tools compact instructions with enough context for tradeoffs.',
  },
];
---

<BaseLayout
  title="Software Practices"
  description="Durable software-development preferences for code, docs, tests, review, and coding agents."
>
  <div class="home-shell">
    <div class="home-content">
      <section class="home-hero">
        <div class="home-version">Reference site</div>
        <h1>Software Practices</h1>
        <p>
          Rules, patterns, checks, and agent instructions for code, docs, tests, review, and source
          control.
        </p>
        <div class="hero-rule" aria-hidden="true"></div>
      </section>

      <section class="intent-grid" aria-label="Site intent">
        <div class="intent-panel">
          <p>
            This site collects repeatable preferences for reviews, repo setup, documentation,
            source control, and coding-agent work.
          </p>
        </div>
        <div class="status-panel">
          <span class="status-dot" aria-hidden="true"></span>
          <strong>Canonical source</strong>
          <span>
            The repo contains <a href={withBase('/guides/')}>guides</a>,
            <a href={withBase('/rules/')}>rules</a>,
            <a href={withBase('/agents/')}>agent snippets</a>,
            <a href={withBase('/agents/core/')}>templates</a>, and
            <a href={withBase('/mechanisms/')}>generated indexes</a> together.
          </span>
        </div>
      </section>

      <section class="home-tasks" aria-labelledby="home-tasks-title">
        <div class="home-section-heading">
          <h2 id="home-tasks-title">Work areas</h2>
          <p>
            Change shape, Rust review, documentation, coding-agent work, and jj workflow each have
            a guide entry.
          </p>
        </div>
        <div class="task-grid">
          {practiceTasks.map((task) => (
            <a class="task-card" href={withBase(task.route)}>
              <strong>{task.title}</strong>
              <span>{task.description}</span>
            </a>
          ))}
        </div>
      </section>

      <section class="home-library" aria-labelledby="home-library-title">
        <div class="home-section-heading">
          <h2 id="home-library-title">Reference sections</h2>
          <p>
            The reference sections separate guides, rules, patterns, principles, mechanisms, tags,
            and agent snippets.
          </p>
        </div>
        <div class="home-card-grid" aria-label="Primary sections">
          {homeCards.map((card) => (
            <a class={`home-card ${card.kind === 'agent' ? 'home-card--agent' : ''}`} href={withBase(card.route)}>
              <h2 class="home-card__title">
                <span class="home-card__icon" aria-hidden="true">
                  <KindIcon kind={card.kind} />
                </span>
                <span>{card.title}</span>
              </h2>
              <p>{card.description}</p>
            </a>
          ))}
        </div>
      </section>

      <section class="home-use" aria-labelledby="how-to-use">
        <div class="home-use__intro">
          <h2 id="how-to-use">Review comments, setup, and agent instructions</h2>
          <p>
            <a href={withBase('/guides/')}>Guides</a> cover broader decisions,
            <a href={withBase('/rules/')}>rules</a> provide compact instructions,
            <a href={withBase('/patterns/')}>patterns</a> name repeatable review moves, and
            <a href={withBase('/mechanisms/')}>mechanisms</a> collect checks, generators,
            and commands.
          </p>
        </div>
        <div class="home-use__cases">
          {useCases.map((item) => (
            <a class="use-case" href={withBase(item.route)}>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </a>
          ))}
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
