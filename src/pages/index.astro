---
import BaseLayout from '../layouts/BaseLayout.astro';
import KindIcon from '../components/KindIcon.astro';
import { practiceTasks, withBase } from '../lib/site';

const homeCards = [
  {
    title: 'Guides',
    kind: 'guide' as const,
    route: '/guides/',
    description: 'Change scope, code shape, Rust review, documentation, agent work, and jj.',
  },
  {
    title: 'Rules',
    kind: 'rule' as const,
    route: '/rules/',
    description: 'Short instructions for documentation, Rust, testing, review, source control, and agents.',
  },
  {
    title: 'Patterns',
    kind: 'pattern' as const,
    route: '/patterns/',
    description: 'Repeatable situations and moves that can be cited in review.',
  },
  {
    title: 'Principles',
    kind: 'principle' as const,
    route: '/why/',
    description: 'Rationale behind related rules and patterns.',
  },
  {
    title: 'Mechanisms',
    kind: 'mechanism' as const,
    route: '/mechanisms/',
    description: 'Commands, checks, generators, and workflows used by the rules and guides.',
  },
  {
    title: 'Agents',
    kind: 'agent' as const,
    route: '/agents/',
    description: 'Copyable instruction packs and rule packs for coding agents.',
  },
  {
    title: 'Tags',
    kind: 'tag' as const,
    route: '/tags/',
    description: 'Documentation, Rust, testing, review, jj, and other topic indexes.',
  },
  {
    title: 'References',
    kind: 'reference' as const,
    route: '/references/',
    description: 'Official documentation, engineering guidelines, design sources, and planning records.',
  },
];

const useCases = [
  {
    title: 'Review comments',
    route: '/patterns/write-pr-narrative/',
    description:
      'Link a named rule or pattern instead of re-explaining the same preference in every PR.',
  },
  {
    title: 'Project setup',
    route: '/agents/core/',
    description:
      'Copy the downstream `AGENTS.md` template and rule pack, then adapt local checks and constraints.',
  },
  {
    title: 'Agent instructions',
    route: '/agents/',
    description:
      'Agent snippets give coding tools compact instructions with enough context for tradeoffs.',
  },
];
---

<BaseLayout
  title="Software Practices"
  description="Durable software-development preferences for code, docs, tests, review, and coding agents."
>
  <div class="home-shell">
    <div class="home-content">
      <section class="home-hero">
        <div class="home-hero__main">
          <div class="home-version">Josh McKinney</div>
          <h1>How I <em class="home-hero__verb" data-home-verb aria-live="off">design</em> software.</h1>
          <p>
            Software-change guidance for humans and coding agents: scope, code structure, Rust
            APIs, documentation, tests, review, and source control.
          </p>
          <div class="home-hero__actions">
            <a class="home-primary-action" href={withBase('/guides/')}>
              Guides by work area <span aria-hidden="true">→</span>
            </a>
            <button class="home-search-action" type="button" data-search-trigger>
              Search rules and patterns <kbd>⌘K</kbd>
            </button>
          </div>
        </div>
        <div class="home-hero__folio" aria-hidden="true">
          <span class="home-hero__folio-label">Development Reference</span>
          <strong>SP.</strong>
          <span class="home-hero__folio-topics">
            Code<br />Docs<br />Rust<br />Review<br />Agents<br />Source Control
          </span>
        </div>
      </section>

      <section class="home-tasks" aria-labelledby="home-tasks-title">
        <div class="home-section-heading">
          <span class="section-kicker">Guides</span>
          <h2 id="home-tasks-title">Work areas</h2>
        </div>
        <div class="task-grid">
          {practiceTasks.map((task, index) => (
            <a class="task-card" href={withBase(task.route)}>
              <span class="task-card__number">0{index + 1}</span>
              <strong class="task-card__title">
                <span>{task.title}</span>
                <span class="card-arrow" aria-hidden="true">→</span>
              </strong>
              <span>{task.description}</span>
            </a>
          ))}
        </div>
      </section>

      <section class="home-library" aria-labelledby="home-library-title">
        <div class="home-section-heading">
          <span class="section-kicker">Reference</span>
          <h2 id="home-library-title">Guidance types</h2>
        </div>
        <div class="home-card-grid" aria-label="Primary sections">
          {homeCards.map((card) => (
            <a class={`home-card home-card--${card.kind}`} href={withBase(card.route)}>
              <h2 class="home-card__title">
                <span class="home-card__icon" aria-hidden="true">
                  <KindIcon kind={card.kind} />
                </span>
                <span>{card.title}</span>
                <span class="card-arrow" aria-hidden="true">→</span>
              </h2>
              <p>{card.description}</p>
            </a>
          ))}
        </div>
      </section>

      <section class="home-use" aria-labelledby="how-to-use">
        <div class="home-use__intro">
          <h2 id="how-to-use">Review comments and repository setup</h2>
        </div>
        <div class="home-use__cases">
          {useCases.map((item) => (
            <a class="use-case" href={withBase(item.route)}>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </a>
          ))}
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<script>
  const rotatingVerb = document.querySelector<HTMLElement>('[data-home-verb]');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  if (rotatingVerb && !reducedMotion.matches) {
    const verbs = [
      'design',
      'write',
      'understand',
      'change',
      'refactor',
      'review',
      'test',
      'document',
      'debug',
      'verify',
      'ship',
      'maintain',
    ];
    let verbIndex = 0;
    let changingVerb = false;

    window.setInterval(async () => {
      if (document.hidden || changingVerb) return;
      changingVerb = true;

      const exit = rotatingVerb.animate(
        [
          { opacity: 1, transform: 'translateY(0)' },
          { opacity: 0, transform: 'translateY(0.1em)' },
        ],
        { duration: 420, easing: 'ease-in', fill: 'forwards' },
      );
      await exit.finished;
      exit.cancel();

      verbIndex = (verbIndex + 1) % verbs.length;
      rotatingVerb.textContent = verbs[verbIndex];

      const enter = rotatingVerb.animate(
        [
          { opacity: 0, transform: 'translateY(-0.1em)' },
          { opacity: 1, transform: 'translateY(0)' },
        ],
        { duration: 460, easing: 'ease-out', fill: 'both' },
      );
      await enter.finished;
      enter.cancel();
      changingVerb = false;
    }, 4600);
  }
</script>
