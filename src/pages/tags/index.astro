---
import BaseLayout from '../../layouts/BaseLayout.astro';
import KindIcon from '../../components/KindIcon.astro';
import {
  guidanceTagDefinitions,
  guidanceTagGroups,
  tagCounts,
  tagLabel,
  withBase,
} from '../../lib/site';

const tags = tagCounts();
const tagGroups = guidanceTagGroups.map((group) => ({
  ...group,
  tags: guidanceTagDefinitions
    .filter(({ family }) => family === group.family)
    .map((definition) => ({
      ...definition,
      count: tags.find(({ tag }) => tag === definition.tag)?.count ?? 0,
    }))
    .filter(({ count }) => count > 0)
    .sort((left, right) => tagLabel(left.tag).localeCompare(tagLabel(right.tag))),
}));
---

<BaseLayout
  title="Tags"
  description="Cross-cutting guidance clusters across rules, patterns, principles, and mechanisms."
>
  <section class="section-hero" aria-labelledby="tags-title">
    <div class="hero-title">
      <span class="hero-title__icon" aria-hidden="true">
        <KindIcon kind="tag" />
      </span>
      <h1 id="tags-title">Tags</h1>
    </div>
    <p>
      Cross-cutting clusters for rules, patterns, principles, and mechanisms. Tags avoid duplicating
      page type, review status, and compactness metadata.
    </p>
  </section>

  <section class="listing tag-index" aria-labelledby="tag-index-title">
    <h2 id="tag-index-title">Guidance tags</h2>
    <div class="grouped-index tag-index__groups">
      {tagGroups.map((group) => (
        <section class="index-group" aria-labelledby={`tag-group-${group.family}`}>
          <div class="index-group__header">
            <h3 id={`tag-group-${group.family}`}>{group.title}</h3>
            <p>{group.description}</p>
          </div>
          <div class="tag-grid">
            {group.tags.map(({ tag, count, description }) => (
              <a class="tag-card" href={withBase(`/tags/${tag}/`)}>
                <span class="tag-card__heading">
                  <span class="tag-card__label">{tagLabel(tag)}</span>
                  <span class="card-arrow" aria-hidden="true">→</span>
                </span>
                <span class="tag-card__description">{description}</span>
                <span class="tag-card__count">{count} {count === 1 ? 'item' : 'items'}</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
