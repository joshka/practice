---
import BaseLayout from '../../layouts/BaseLayout.astro';
import KindIcon from '../../components/KindIcon.astro';
import {
  guidanceTags,
  guidanceTagDefinition,
  taggedPages,
  tagLabel,
  tagSlug,
  tagsForPage,
  withBase,
} from '../../lib/site';
import type { MarkdownPage } from '../../lib/site';

type GuidanceKind = 'agent' | 'guide' | 'rule' | 'pattern' | 'principle' | 'mechanism';

type PageGroup = {
  id: string;
  entries: MarkdownPage[];
  kind: GuidanceKind;
  label: string;
  navLabel: string;
};

export function getStaticPaths() {
  return guidanceTags.map((tag) => ({ params: { tag } }));
}

const tag = tagSlug(Astro.params.tag ?? '');
const title = tagLabel(tag);
const tagDefinition = guidanceTagDefinition(tag);
const pages = taggedPages(tag);
const guidanceKindOrder: GuidanceKind[] = [
  'guide',
  'rule',
  'pattern',
  'principle',
  'mechanism',
  'agent',
];

function pageKind(page: MarkdownPage): GuidanceKind {
  if (page.repoPath.startsWith('guides/')) return 'guide';
  if (page.repoPath.startsWith('patterns/')) return 'pattern';
  if (page.repoPath.startsWith('principles/')) return 'principle';
  if (page.repoPath.startsWith('mechanisms/')) return 'mechanism';
  if (page.repoPath.startsWith('snippets/agents/')) return 'agent';
  return 'rule';
}

function pageKindLabel(page: MarkdownPage): string {
  return tagLabel(pageKind(page));
}

function ruleDomain(page: MarkdownPage): string {
  return tagSlug(page.metadata.domain ?? page.repoPath.split('/')[1] ?? 'other');
}

function groupsForKind(kind: GuidanceKind): PageGroup[] {
  const entries = pages.filter((page) => pageKind(page) === kind);
  if (kind !== 'rule') {
    return entries.length === 0
      ? []
      : [{
          id: kind,
          entries,
          kind,
          label: `${tagLabel(kind)} ${entries.length === 1 ? 'item' : 'items'}`,
          navLabel: tagLabel(kind),
        }];
  }

  const domains = [...new Set(entries.map(ruleDomain))];
  return domains.map((domain) => ({
    id: `rule-${domain}`,
    entries: entries.filter((page) => ruleDomain(page) === domain),
    kind,
    label: `${tagLabel(domain)} rules`,
    navLabel: `${tagLabel(domain)} rules`,
  }));
}

const pageGroups = guidanceKindOrder.flatMap(groupsForKind);
---

<BaseLayout
  title={title}
  description={tagDefinition?.description ?? `Guidance tagged ${title}.`}
  breadcrumbs={[
    { label: 'Tags', href: '/tags/' },
  ]}
>
  <section class="section-hero tag-hero" aria-labelledby="tag-title">
    <div class="hero-title">
      <span class="hero-title__icon" aria-hidden="true">
        <KindIcon kind="tag" />
      </span>
      <h1 id="tag-title">{title}</h1>
    </div>
    <p>{tagDefinition?.description}</p>
    <p class="tag-hero__count">
      {pages.length} {pages.length === 1 ? 'item' : 'items'} in this guidance cluster.
    </p>
  </section>

  <section class="listing tag-results" aria-labelledby="tag-results-title">
    <h2 id="tag-results-title">Tagged guidance</h2>
    {pageGroups.length > 1 && (
      <nav class="group-nav tag-group-nav" aria-label={`${title} guidance groups`}>
        {pageGroups.map((group) => (
          <a href={`#tag-${tag}-${group.id}`}>
            <span>{group.navLabel}</span>
            <small>{group.entries.length}</small>
          </a>
        ))}
      </nav>
    )}
    <div class="grouped-index grouped-index--compact">
      {pageGroups.map((group) => (
        <section class="index-group" aria-labelledby={`tag-${tag}-${group.id}`}>
          <div class="index-group__header">
            <h3 id={`tag-${tag}-${group.id}`}>{group.label}</h3>
          </div>
          <div class="index-list index-list--cards">
            {group.entries.map((page) => (
              <a class="index-entry index-entry--with-icon" href={withBase(page.route)}>
                <span class="index-entry__body">
                  <span class="index-entry__tags">
                    <span class="index-entry__tag">
                      <span class="index-entry__kind-icon" aria-hidden="true">
                        <KindIcon kind={pageKind(page)} />
                      </span>
                      {pageKindLabel(page)}
                    </span>
                    {tagsForPage(page).filter((pageTag) => pageTag !== tag).slice(0, 3).map((pageTag) => (
                      <span class="index-entry__tag">{tagLabel(pageTag)}</span>
                    ))}
                  </span>
                  <span class="index-entry__title">
                    <strong>{page.title}</strong>
                    <span class="card-arrow" aria-hidden="true">→</span>
                  </span>
                  {page.metadata.id && <span class="index-entry__id">{page.metadata.id}</span>}
                  {page.description && <span class="index-entry__description">{page.description}</span>}
                </span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
