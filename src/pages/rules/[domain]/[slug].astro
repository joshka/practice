---
import PageContent from '../../../components/PageContent.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { renderMarkdown, ruleDomains, rulesForDomain } from '../../../lib/site';

export function getStaticPaths() {
  return ruleDomains().flatMap((domainPage) => {
    const domain = domainPage.repoPath.split('/')[1];
    return rulesForDomain(domain).map((page) => ({
      params: { domain, slug: page.repoPath.split('/').at(-1)?.replace(/\.md$/, '') },
      props: { page },
    }));
  });
}

const page = Astro.props.page;
const domain = Astro.params.domain ?? '';
const domainPage = renderMarkdown(`rules/${domain}/README.md`);
---

<BaseLayout
  title={page.title}
  description={page.description}
  sourceUrl={page.sourceUrl}
  breadcrumbs={[
    { label: 'Rules', href: '/rules/' },
    { label: domainPage.title, href: domainPage.route },
  ]}
>
  <PageContent page={page} />
</BaseLayout>
