---
import BaseLayout from '../../layouts/BaseLayout.astro';
import KindIcon from '../../components/KindIcon.astro';
import { renderMarkdown, ruleDomains, rulesForDomain, withBase } from '../../lib/site';

const page = renderMarkdown('rules/README.md');
const domainTags: Record<string, string> = {
  'agent-workflow': 'AGENT',
  boundary: 'BOUNDARY',
  'change-shape': 'CHANGE',
  documentation: 'DOCS',
  observability: 'OBSERVE',
  performance: 'PERF',
  refactoring: 'REFACTOR',
  review: 'REVIEW',
  rust: 'RUST',
  source: 'SOURCE',
  'test-failures': 'FAILURE',
  testing: 'TEST',
  vcs: 'VCS',
};
const domains = ruleDomains().map((domain) => {
  const key = domain.repoPath.split('/')[1] ?? '';
  return {
    ...domain,
    count: rulesForDomain(key).length,
    tag: domainTags[key] ?? 'RULE',
  };
});
const ruleCount = domains.reduce((sum, domain) => sum + domain.count, 0);
---

<BaseLayout title={page.title} description={page.description} sourceUrl={page.sourceUrl}>
  <div class="rules-shell">
    <section class="rules-hero" aria-labelledby="rules-title">
      <div class="hero-title">
        <span class="hero-title__icon" aria-hidden="true">
          <KindIcon kind="rule" />
        </span>
        <h1 id="rules-title">Rules</h1>
      </div>
      <p>
        Compact rules for common engineering decisions, grouped by work area: documentation, Rust
        APIs, testing, review, source control, and agent workflow.
      </p>
      <div class="rules-stats" aria-label="Rule catalog summary">
        <span><strong>{ruleCount}</strong> rules</span>
        <span><strong>{domains.length}</strong> domains</span>
        <span><strong>1</strong> compressed agent pack</span>
      </div>
    </section>

    <section class="rules-use" aria-labelledby="rules-use-title">
      <div>
        <h2 id="rules-use-title">Rule work areas</h2>
      </div>
      <div class="rules-use__steps">
        <p>
          Tags mark work areas: <strong>DOCS</strong> for documentation, <strong>VCS</strong> for
          jj and source control, <strong>RUST</strong> for crate shape, and <strong>AGENT</strong>
          for coding-agent work.
        </p>
        <p>
          Rule pages include rationale, limits, mechanisms, and source links. Downstream
          repositories can copy compact instructions without copying the full explanation.
        </p>
        <p><a class="inline-action" href={withBase('/agents/rules/')}>Agent rule pack</a></p>
      </div>
    </section>

    <section class="rules-domains" aria-labelledby="rule-domains-title">
      <h2 id="rule-domains-title">Rule work areas</h2>
      <div class="rules-domain-grid">
        {domains.map((domain) => (
          <a class="rules-domain-card" href={withBase(domain.route)}>
            <span class="rules-domain-card__meta">
              <span class="rules-domain-card__label">
                <span class="rules-domain-card__kind-icon" aria-hidden="true">
                  <KindIcon kind="rule" />
                </span>
                <span class="rules-domain-card__tag">{domain.tag}</span>
              </span>
              <span class="rules-domain-card__count">
                {domain.count} {domain.count === 1 ? 'rule' : 'rules'}
              </span>
            </span>
            <strong>{domain.title}</strong>
            {domain.description && <span>{domain.description}</span>}
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
