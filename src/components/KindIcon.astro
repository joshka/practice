---
import {
  faBook,
  faBrain,
  faCompassDrafting,
  faGlobe,
  faRobot,
  faRuler,
  faTags,
  faWrench,
} from '@fortawesome/free-solid-svg-icons';

type GuidanceKind =
  | 'agent'
  | 'guide'
  | 'rule'
  | 'pattern'
  | 'principle'
  | 'mechanism'
  | 'reference'
  | 'tag';

type Props = {
  kind: GuidanceKind;
  label?: string;
};

const { kind, label } = Astro.props;
const icons = {
  agent: faRobot,
  guide: faBook,
  rule: faRuler,
  pattern: faCompassDrafting,
  principle: faBrain,
  mechanism: faWrench,
  reference: faGlobe,
  tag: faTags,
} satisfies Record<GuidanceKind, typeof faRuler>;
const icon = icons[kind];
const [width, height, , , path] = icon.icon;
const isMeaningful = Boolean(label);
const pathData = Array.isArray(path) ? path.join(' ') : path;
---

<svg
  class={`kind-icon kind-icon--${kind}`}
  aria-hidden={isMeaningful ? undefined : 'true'}
  aria-label={isMeaningful ? label : undefined}
  role={isMeaningful ? 'img' : undefined}
  viewBox={`0 0 ${width} ${height}`}
  fill="currentColor"
  focusable="false"
>
  <path d={pathData} />
</svg>
