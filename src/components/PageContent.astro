---
import KindIcon from './KindIcon.astro';
import { allPublicPages, repoUrl, tagLabel, tagSlug, tagsForPage, withBase } from '../lib/site';
import type { MarkdownPage } from '../lib/site';

type Props = {
  page: MarkdownPage;
};

const { page } = Astro.props;
const kind = pageKind(page.repoPath);
const chips = metadataChips(page);
const isReviewable = isReviewableKind(kind);
const showHeaderDescription = !isReviewable && kind !== 'agent-snippet';
const showIntro = kind === 'agent-snippet' || (page.sections.length === 0 && kind === 'default');
const iconKind = pageIconKind(kind);
const reviewNote = reviewCopyMarkdown(page, kind);
const citationNote = citationCopyMarkdown(page, kind);
const feedbackUrl = feedbackIssueUrl(page, kind, Astro.site?.href ?? 'https://joshka.net');
const heroTitle = page.title;
const heroId = isReviewable && page.metadata.id && page.title !== page.metadata.id
  ? page.metadata.id
  : undefined;
const summary = isReviewable ? page.metadata.summary : undefined;
const relatedPages = relatedGuidancePages(page);

type IconKind = 'agent' | 'guide' | 'rule' | 'pattern' | 'principle' | 'mechanism' | 'reference';

function pageKind(repoPath: string): string {
  if (repoPath.startsWith('rules/') && !repoPath.endsWith('/README.md')) return 'rule';
  if (repoPath.startsWith('patterns/')) return 'pattern';
  if (repoPath.startsWith('principles/')) return 'principle';
  if (repoPath.startsWith('mechanisms/')) return 'mechanism';
  if (repoPath.startsWith('references/')) return 'reference';
  if (repoPath.startsWith('snippets/agents/')) return 'agent-snippet';
  if (repoPath.startsWith('guides/')) return 'guide';
  return 'default';
}

function metadataChips(page: MarkdownPage): string[] {
  const chips: string[] = [];
  if (page.metadata.audience && page.metadata.audience !== 'both') chips.push(page.metadata.audience);
  for (const tag of tagsForPage(page)) {
    if (chips.length >= 6) break;
    chips.push(tag);
  }
  return [...new Set(chips)];
}

function formatChip(value: string): string {
  return value.replace(/[-_]+/g, ' ').toUpperCase();
}

function sectionClass(title: string): string {
  return title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

function isAgentInstruction(title: string): boolean {
  return title.toLowerCase() === 'agent instruction';
}

function pageIconKind(value: string): IconKind | undefined {
  if (value === 'agent-snippet') return 'agent';
  if (value === 'guide') return 'guide';
  if (value === 'mechanism') return 'mechanism';
  if (value === 'pattern') return 'pattern';
  if (value === 'principle') return 'principle';
  if (value === 'reference') return 'reference';
  if (value === 'rule') return 'rule';
  return undefined;
}

function isReviewableKind(value: string): boolean {
  return value === 'rule' || value === 'pattern' || value === 'principle';
}

function isFeedbackableKind(value: string): boolean {
  return (
    value === 'guide' ||
    value === 'rule' ||
    value === 'pattern' ||
    value === 'principle' ||
    value === 'mechanism'
  );
}

function feedbackIssueUrl(page: MarkdownPage, kind: string, site: string): string | undefined {
  if (!isFeedbackableKind(kind)) return undefined;

  const itemUrl = new URL(withBase(page.route), site).href;
  const itemId = page.metadata.id || page.title;
  const url = new URL(`${repoUrl}/issues/new`);
  url.searchParams.set('template', 'guidance-feedback.yml');
  url.searchParams.set('title', `Feedback: ${itemId}`);
  url.searchParams.set('item_url', itemUrl);
  url.searchParams.set('item_file', page.repoPath);
  url.searchParams.set('item_id', itemId);
  url.searchParams.set('item_kind', kind);
  return url.href;
}

function reviewCopyMarkdown(page: MarkdownPage, kind: string): string | undefined {
  if (!isReviewableKind(kind)) return undefined;

  const summary = reviewSummary(page, kind);
  if (!summary) return undefined;

  const url = new URL(withBase(page.route), 'https://joshka.net').href;
  const linkedLabel = page.metadata.id ? `\`${page.metadata.id}\`` : page.title;
  const namePrefix = page.metadata.id && page.title ? `${page.title}. ` : '';
  return `[${linkedLabel}](${url}): ${namePrefix}${summary}`;
}

function citationCopyMarkdown(page: MarkdownPage, kind: string): string | undefined {
  if (isReviewableKind(kind)) return undefined;
  if (!isCitableKind(kind)) return undefined;

  const summary = page.metadata.summary || page.description;
  if (!summary) return undefined;

  const url = new URL(withBase(page.route), 'https://joshka.net').href;
  const linkedLabel = page.metadata.id ? `\`${page.metadata.id}\`` : page.title;
  const namePrefix = page.metadata.id && page.title ? `${page.title}. ` : '';
  return `[${linkedLabel}](${url}): ${namePrefix}${summary}`;
}

function isCitableKind(value: string): boolean {
  return value === 'guide' || value === 'mechanism' || value === 'agent-snippet';
}

function reviewSummary(page: MarkdownPage, kind: string): string {
  if (page.metadata.summary) return page.metadata.summary;

  const preferredSection = {
    rule: 'rule',
    pattern: 'preferred move',
    principle: 'claim',
  }[kind];
  const section = page.sections.find((section) => section.title.toLowerCase() === preferredSection);
  return (section?.markdown || page.description).trim();
}

function relatedGuidancePages(page: MarkdownPage): MarkdownPage[] {
  const related = page.metadata.related
    ?.split(',')
    .map((value) => value.trim().toLowerCase())
    .filter(Boolean) ?? [];
  if (related.length === 0) return [];

  const pagesById = new Map(
    allPublicPages()
      .filter((candidate) => candidate.metadata.id && candidate.route !== page.route)
      .map((candidate) => [candidate.metadata.id.toLowerCase(), candidate]),
  );
  const pagesByPath = new Map(
    allPublicPages()
      .filter((candidate) => candidate.route !== page.route)
      .map((candidate) => [candidate.repoPath.toLowerCase(), candidate]),
  );
  return related
    .map((id) => pagesById.get(id) ?? pagesByPath.get(id))
    .filter((candidate): candidate is MarkdownPage => Boolean(candidate));
}

function relatedLabel(page: MarkdownPage): string {
  return page.metadata.id || page.title;
}
---

<article class={`page page--${kind}`}>
  <header class="detail-hero">
    <div class="hero-title">
      {iconKind && (
        <span class="hero-title__icon" aria-hidden="true">
          <KindIcon kind={iconKind} />
        </span>
      )}
      <h1>{heroTitle}</h1>
    </div>
    {heroId && <p class="detail-hero__id">{heroId}</p>}
    {showHeaderDescription && page.description && <p>{page.description}</p>}
    {(chips.length > 0 || reviewNote || citationNote || feedbackUrl) && (
      <div class="detail-hero__meta" aria-label="Page topics">
        <div class="detail-hero__chips">
          {chips.map((chip) => (
            chip.includes('-') || tagsForPage(page).includes(tagSlug(chip)) ? (
              <a class="detail-chip" href={withBase(`/tags/${tagSlug(chip)}/`)}>{tagLabel(chip)}</a>
            ) : (
              <span class="detail-chip">{formatChip(chip)}</span>
            )
          ))}
        </div>
        {reviewNote && (
          <button class="detail-copy" type="button" data-copy-markdown={reviewNote}>
            Copy review note
          </button>
        )}
        {citationNote && (
          <button class="detail-copy" type="button" data-copy-markdown={citationNote}>
            Copy citation
          </button>
        )}
        {feedbackUrl && (
          <a class="detail-action detail-action--secondary" href={feedbackUrl}>
            Give feedback
          </a>
        )}
      </div>
    )}
  </header>

  {showIntro && page.introHtml && <div class="prose detail-intro" set:html={page.introHtml} />}

  {summary && (
    <section class="detail-summary" aria-labelledby="detail-summary-title">
      <h2 id="detail-summary-title">Summary</h2>
      <p>{summary}</p>
    </section>
  )}

  {relatedPages.length > 0 && (
    <nav class="detail-related" aria-labelledby="detail-related-title">
      <h2 id="detail-related-title">Related</h2>
      <div class="detail-related__links">
        {relatedPages.map((related) => (
          <a href={withBase(related.route)}>
            <strong>{relatedLabel(related)}</strong>
            <span>{related.title}</span>
          </a>
        ))}
      </div>
    </nav>
  )}

  <div class="detail-sections">
    {page.sections.map((section) => (
      <section class={`detail-section detail-section--${sectionClass(section.title)}`}>
        <h2>{section.title}</h2>
        {isAgentInstruction(section.title) ? (
          <div class="prose detail-section__body detail-section__body--code">
            <div class="code-block">
              <button class="code-block__copy" type="button">Copy</button>
              <pre><code>{section.markdown}</code></pre>
            </div>
          </div>
        ) : (
          <div class="prose detail-section__body" set:html={section.html} />
        )}
      </section>
    ))}
  </div>
</article>
